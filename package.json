  "types": "lib/index.d.ts",
  "stability": "stable",
  "jsii": {
    "outdir": "dist",
    "targets": {
      "python": {
        "distName": "cdk-circleci-oidc",
        "module": "cdk_circleci_oidc"
      }
    },
    "tsc": {
      "outDir": "lib",
      "rootDir": "src"
    }
